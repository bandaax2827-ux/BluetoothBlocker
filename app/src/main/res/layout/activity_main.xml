<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Заголовок -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bluetooth Blocker"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1E88E5"
            android:layout_marginBottom="8dp"/>

        <!-- Версия -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1.5.3"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginBottom="24dp"/>

        <!-- Статус Root -->
        <TextView
            android:id="@+id/tvRoot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Проверка root..."
            android:textSize="16sp"
            android:layout_marginBottom="24dp"/>

        <!-- Карточка: Главный переключатель -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛡️ Режим Сторож"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1E88E5"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Постоянно следит за Bluetooth и отключает его при включении"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="16dp"
                    android:lineSpacingExtra="4dp"/>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchBlock"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Заблокировать Bluetooth"
                    android:textSize="16sp"
                    android:padding="8dp"/>

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bluetooth: свободен"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#4CAF50"
                    android:layout_marginTop="12dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Карточка: Жёсткий режим -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️ Жёсткий режим"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Отключает системное приложение Bluetooth. Кнопки BT исчезнут. Чтобы вернуть — выключи этот режим."
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="16dp"
                    android:lineSpacingExtra="4dp"/>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchHard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Жёсткий режим"
                    android:textSize="16sp"
                    android:padding="8dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Карточка: Батарея -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔋 Батарея"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#4CAF50"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Чтобы Android не убивал сторожа в фоне, разреши игнорировать оптимизацию батареи."
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="16dp"
                    android:lineSpacingExtra="4dp"/>

                <Button
                    android:id="@+id/btnBattery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Разрешить игнорировать батарею"
                    android:textSize="14sp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Карточка: Безопасное удаление -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🗑️ Безопасное удаление"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#F44336"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Это безопасное удаление. Мы восстановим Bluetooth, прежде чем удалить приложение. Не рекомендуем удалять вручную, если вы не выключили блокировку Bluetooth, иначе вы потеряете Bluetooth навсегда и переустановка приложения может не помочь."
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="16dp"
                    android:lineSpacingExtra="4dp"/>

                <Button
                    android:id="@+id/btnSafeDelete"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Безопасно удалить"
                    android:textSize="14sp"
                    android:backgroundTint="#F44336"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
