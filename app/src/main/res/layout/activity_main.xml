<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal">

        <!-- Заголовок -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bluetooth Blocker"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1E88E5"
            android:layout_marginBottom="4dp"/>

        <!-- Версия -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1.8.0.1 made with Qwen from X Banda"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="16dp"/>

        <!-- Статус Root -->
        <TextView
            android:id="@+id/tvRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Проверка root..."
            android:textSize="15sp"
            android:gravity="center"
            android:padding="8dp"
            android:background="#E3F2FD"
            android:layout_marginBottom="12dp"/>

        <!-- Карточка: Главный переключатель -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛡️ Режим Сторож"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#1E88E5"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Постоянно следит за Bluetooth и отключает его при включении"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchBlock"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Заблокировать Bluetooth"
                    android:textSize="15sp"
                    android:padding="4dp"/>

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bluetooth: свободен"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#4CAF50"
                    android:gravity="center"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Карточка: Жёсткий режим -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️ Жёсткий режим"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Отключает системное приложение Bluetooth. Кнопки BT исчезнут. Чтобы вернуть — выключи этот режим."
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchHard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Жёсткий режим"
                    android:textSize="15sp"
                    android:padding="4dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Карточка: Батарея -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" Батарея"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#4CAF50"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Чтобы Android не убивал сторожа в фоне, разреши игнорировать оптимизацию батареи."
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnBattery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔋 Разрешить игнорировать батарею"
                    android:textSize="14sp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Карточка: Родительская зона -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👨‍👩‍👧 Родительская зона"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#9C27B0"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ваш ребёнок подключает устройства по Bluetooth? Включите блокировку и заблокируйте переключатели и удаление, чтобы ребёнок не мог подключиться и не мог удалить блокировщик."
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnParentalZone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔒 Блокировать переключатели и удаление"
                    android:textSize="14sp"
                    android:backgroundTint="#9C27B0"/>

                <TextView
                    android:id="@+id/tvParentalStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Родительская зона: выключена"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#F44336"
                    android:gravity="center"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Карточка: Безопасное удаление -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🗑️ Безопасное удаление"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#F44336"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Мы восстановим Bluetooth, прежде чем удалить приложение. Не удаляйте вручную, если не выключили блокировку — потеряете Bluetooth навсегда."
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnSafeDelete"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🗑️ Безопасно удалить"
                    android:textSize="14sp"
                    android:backgroundTint="#F44336"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
